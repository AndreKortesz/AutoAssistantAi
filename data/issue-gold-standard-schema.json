{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoassistant-issue-gold-standard-v1.1",
  "title": "AutoAssistantAi — Gold Standard болячки v1.1",
  "description": "Эталонная схема описания болячки автомобиля. Основана на структуре мышления опытного владельца. Версия 1.1 включает блок defect_status, расширенный enum solution.type, type на корне для классификации записей, поля для climate-зависимости, history тегов и DIY оценки сложности.",
  
  "type": "object",
  "required": ["id", "type", "car", "issue"],
  
  "properties": {
    
    "id": {
      "type": "string",
      "description": "Уникальный ID болячки",
      "example": "mustang_6g_ecoboost_fuel_sensor"
    },
    
    "version": {
      "type": "string",
      "description": "Версия записи для отслеживания обновлений",
      "example": "1.0.0"
    },
    
    "created_at": {
      "type": "string",
      "format": "date",
      "example": "2025-01-21"
    },
    
    "updated_at": {
      "type": "string", 
      "format": "date",
      "example": "2025-01-21"
    },

    "type": {
      "type": "string",
      "description": "Тип записи. Определяет, на какой странице UI она показывается.",
      "enum": ["systemic_defect", "common_wear", "maintenance", "minor_annoyance", "rare", "discarded_rare"],
      "example": "systemic_defect"
    },

    "type_reason": {
      "type": "string",
      "description": "Обоснование классификации. Особенно важно для systemic_defect (>10% частота, recall, TSB) и discarded_rare (почему отброшено).",
      "example": "частота >15%, подтверждено Drive2 + 2 независимых источника"
    },

    "car": {
      "type": "object",
      "description": "КОНТЕКСТ — какой автомобиль затронут",
      "required": ["brand", "model", "generation"],
      "properties": {
        "brand": {
          "type": "string",
          "example": "Ford"
        },
        "model": {
          "type": "string",
          "example": "Mustang"
        },
        "generation": {
          "type": "string",
          "description": "Поколение с внутренним кодом",
          "example": "6G (S550)"
        },
        "year_start": {
          "type": "integer",
          "example": 2015
        },
        "year_end": {
          "type": ["integer", "null"],
          "description": "null = актуально по сей день",
          "example": 2023
        },
        "engine": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "example": "2.3L EcoBoost"
            },
            "displacement": {
              "type": "number",
              "example": 2.3
            },
            "power_hp": {
              "type": "integer",
              "example": 310
            },
            "fuel": {
              "type": "string",
              "enum": ["бензин", "дизель", "гибрид", "электро"],
              "example": "бензин"
            },
            "turbo": {
              "type": "boolean",
              "example": true
            },
            "fuel_requirements": {
              "type": "object",
              "description": "Требования к топливу. Помогает UI показать предупреждение (например, 'АИ-92 ускоряет разрушение катализатора').",
              "properties": {
                "octane_min": {
                  "type": "integer",
                  "description": "Минимально допустимое октановое число",
                  "example": 92
                },
                "octane_recommended": {
                  "type": "integer",
                  "description": "Рекомендуемое октановое число",
                  "example": 95
                },
                "compatible": {
                  "type": "array",
                  "items": {"type": "string"},
                  "example": ["АИ-92", "АИ-95", "АИ-98"]
                },
                "warning": {
                  "type": ["string", "null"],
                  "description": "Предупреждение о топливе если есть",
                  "example": "АИ-92 ускоряет разрушение катализатора"
                }
              }
            }
          }
        },
        "transmission": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "example": "10R80"
            },
            "type": {
              "type": "string",
              "enum": ["МКПП", "АКПП", "Робот", "Вариатор"],
              "example": "АКПП"
            },
            "gears": {
              "type": "integer",
              "example": 10
            }
          }
        },
        "body_type": {
          "type": "string",
          "enum": ["Седан", "Хэтчбек", "Универсал", "Кроссовер", "Внедорожник", "Купе", "Кабриолет"],
          "example": "Купе"
        },
        "market": {
          "type": "string",
          "description": "Рынок сбыта (влияет на комплектацию)",
          "enum": ["USA", "EU", "RU", "Asia"],
          "example": "USA"
        },
        "facelift": {
          "type": "string",
          "description": "Дорест/Рест если важно",
          "enum": ["дорест", "рест", "любой"],
          "example": "дорест"
        }
      }
    },

    "issue": {
      "type": "object",
      "description": "СИМПТОМ + ПРИЧИНА — что сломалось и почему",
      "required": ["title", "system", "severity"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Краткое название болячки",
          "example": "Датчик топлива старой ревизии"
        },
        "title_short": {
          "type": "string",
          "description": "Для UI — максимум 30 символов",
          "example": "Датчик топлива"
        },
        "system": {
          "type": "string",
          "description": "Основная система автомобиля",
          "enum": ["engine", "transmission", "suspension", "brakes", "body", "electrical", "cooling", "fuel", "exhaust", "interior"],
          "example": "fuel"
        },
        "subsystem": {
          "type": "string",
          "description": "Подсистема для детализации",
          "example": "fuel_pressure"
        },
        "severity": {
          "type": "string",
          "description": "Критичность проблемы",
          "enum": ["critical", "high", "medium", "low"],
          "example": "critical"
        },
        "severity_reason": {
          "type": "string",
          "description": "Почему такая критичность",
          "example": "Может привести к критическому отказу двигателя"
        },
        "can_drive": {
          "type": "boolean",
          "description": "Можно ли ездить с этой проблемой",
          "example": false
        },
        "symptoms": {
          "type": "array",
          "description": "Как проявляется — что видит/слышит/чувствует владелец",
          "items": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "example": "Плавающие обороты холостого хода"
              },
              "conditions": {
                "type": "string",
                "description": "При каких условиях проявляется",
                "example": "на прогретом двигателе"
              }
            }
          },
          "example": [
            {"description": "Плавающие обороты", "conditions": "на холостом ходу"},
            {"description": "Потеря мощности", "conditions": "при разгоне"}
          ]
        },
        "obd_codes": {
          "type": "array",
          "description": "Коды ошибок OBD-II",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "P008A"
              },
              "description": {
                "type": "string",
                "example": "Low Pressure Fuel System Pressure - Too Low"
              }
            }
          },
          "example": [
            {"code": "P008A", "description": "Давление в топливной системе слишком низкое"},
            {"code": "P0148", "description": "Ошибка подачи топлива"},
            {"code": "P018C", "description": "Диапазон/производительность датчика давления топлива"}
          ]
        },
        "cause": {
          "type": "object",
          "description": "ПРИЧИНА — почему это происходит",
          "properties": {
            "primary": {
              "type": "string",
              "description": "Основная причина",
              "example": "Датчик топлива старого образца отправляет ложные данные в ECU"
            },
            "secondary": {
              "type": "array",
              "description": "Альтернативные/сопутствующие причины",
              "items": {"type": "string"},
              "example": ["Окисление контактов", "Брак партии"]
            },
            "not_cause": {
              "type": "array",
              "description": "Что НЕ является причиной (частые ошибки диагностики)",
              "items": {"type": "string"},
              "example": ["Топливный насос", "Форсунки"]
            },
            "root_cause_type": {
              "type": "string",
              "enum": ["конструктивный_дефект", "износ", "эксплуатация", "внешние_факторы", "брак_партии"],
              "example": "конструктивный_дефект"
            }
          }
        }
      }
    },

    "consequences": {
      "type": "object",
      "description": "ПОСЛЕДСТВИЯ — что будет если не починить",
      "properties": {
        "description": {
          "type": "string",
          "description": "Что произойдёт если игнорировать проблему",
          "example": "При обрыве цепи — встреча поршней с клапанами"
        },
        "worst_case": {
          "type": "string",
          "description": "Худший сценарий",
          "example": "Замена двигателя"
        },
        "worst_case_cost_rub": {
          "type": "object",
          "properties": {
            "min": {"type": "integer"},
            "max": {"type": "integer"},
            "as_of_date": {"type": "string", "format": "date"}
          },
          "example": {"min": 200000, "max": 350000, "as_of_date": "2025-01"}
        },
        "repair_if_ignored_cost_rub": {
          "type": "object",
          "description": "Стоимость ремонта если запустить (например, ремонт ГБЦ)",
          "properties": {
            "min": {"type": "integer"},
            "max": {"type": "integer"},
            "as_of_date": {"type": "string", "format": "date"}
          },
          "example": {"min": 80000, "max": 150000, "as_of_date": "2025-01"}
        },
        "time_to_failure": {
          "type": "string",
          "description": "Сколько можно ездить до критического отказа",
          "example": "от нескольких дней до нескольких месяцев"
        }
      }
    },

    "history": {
      "type": "object",
      "description": "ИСТОРИЯ — когда появилась и исправлена проблема",
      "properties": {
        "known_since_year": {
          "type": "integer",
          "description": "С какого года известна проблема",
          "example": 2010
        },
        "fixed_in_year": {
          "type": ["integer", "null"],
          "description": "В каком году производитель исправил (null = не исправлено)",
          "example": 2012
        },
        "fixed_description": {
          "type": "string",
          "description": "Что именно исправили",
          "example": "VAG модернизировал натяжитель цепи"
        },
        "affected_years": {
          "type": "array",
          "description": "Годы выпуска с проблемой",
          "items": {"type": "integer"},
          "example": [2010, 2011]
        },
        "safe_years": {
          "type": "array",
          "description": "Годы выпуска без проблемы (после исправления)",
          "items": {"type": "integer"},
          "example": [2012, 2013, 2014, 2015]
        },
        "tsb_date": {
          "type": "string",
          "format": "date",
          "description": "Дата выпуска TSB (Technical Service Bulletin)",
          "example": "2012-03-15"
        },
        "recall_date": {
          "type": "string",
          "format": "date",
          "description": "Дата отзывной кампании",
          "example": null
        }
      }
    },

    "defect_status": {
      "type": "object",
      "description": "ЮРИДИЧЕСКИЙ СТАТУС ДЕФЕКТА — recall, class action, TSB, исправление в производстве. Используется на UI для метки 'Признано производителем' и для блока 'Защита прав'.",
      "properties": {
        "is_acknowledged": {
          "type": "boolean",
          "description": "Признан ли дефект производителем",
          "example": true
        },
        "acknowledged_by": {
          "type": ["string", "null"],
          "description": "Кто признал — производитель, регулятор",
          "example": "Hyundai"
        },
        "acknowledged_date": {
          "type": ["string", "null"],
          "format": "date",
          "example": "2017-06-15"
        },
        "class_actions": {
          "type": "array",
          "description": "Коллективные иски по этому дефекту",
          "items": {
            "type": "object",
            "properties": {
              "country": {"type": "string", "example": "США"},
              "country_flag": {"type": "string", "example": "🇺🇸"},
              "year": {"type": ["integer", "null"], "example": 2022},
              "plaintiffs_count": {"type": ["integer", "null"]},
              "status": {
                "type": "string",
                "enum": ["pending", "won", "lost", "settlement", "dismissed", "withdrawn"],
                "example": "dismissed"
              },
              "result": {
                "type": ["string", "null"],
                "description": "Краткий результат",
                "example": "Иск добровольно отозван истцами 22.06.2023"
              },
              "case_number": {
                "type": ["string", "null"],
                "example": "8:22-cv-00448-SPG-KES"
              },
              "description": {"type": "string"},
              "source_url": {"type": ["string", "null"]}
            }
          }
        },
        "related_recalls": {
          "type": "array",
          "description": "Отзывные кампании по этому дефекту",
          "items": {
            "type": "object",
            "properties": {
              "country": {"type": "string", "example": "США"},
              "country_flag": {"type": "string", "example": "🇺🇸"},
              "recall_id": {
                "type": ["string", "null"],
                "description": "Официальный ID отзыва (NHTSA, Транспорт Канада, Росстандарт и т.д.)",
                "example": "23V-651000"
              },
              "campaign_code": {
                "type": ["string", "null"],
                "description": "Код кампании производителя",
                "example": "Hyundai 251"
              },
              "date": {"type": ["string", "null"], "format": "date"},
              "year": {"type": ["integer", "null"], "example": 2023},
              "description": {"type": "string"},
              "affected_units": {
                "type": ["integer", "null"],
                "description": "Сколько автомобилей затронуто",
                "example": 240589
              },
              "status": {
                "type": "string",
                "enum": ["open", "active", "completed", "unknown"],
                "example": "open"
              },
              "source_url": {"type": ["string", "null"]}
            }
          }
        },
        "tsb": {
          "type": "array",
          "description": "Technical Service Bulletins производителя",
          "items": {
            "type": "object",
            "properties": {
              "code": {"type": "string", "example": "TSB 17-06-15"},
              "date": {"type": ["string", "null"], "format": "date"},
              "description": {"type": "string"},
              "country": {"type": ["string", "null"]},
              "country_flag": {"type": ["string", "null"]}
            }
          }
        },
        "fix_in_production": {
          "type": "object",
          "description": "Когда производитель исправил дефект на конвейере",
          "properties": {
            "date": {"type": ["string", "null"], "format": "date"},
            "description": {"type": ["string", "null"], "example": "Перешли на ревизию B катколлектора"}
          }
        }
      }
    },

    "mileage": {
      "type": "object",
      "description": "ПРОБЕГ — когда проявляется",
      "properties": {
        "typical_start_km": {
          "type": "integer",
          "description": "Обычно начинается с этого пробега",
          "example": 0
        },
        "typical_end_km": {
          "type": ["integer", "null"],
          "description": "До какого пробега актуально (null = всегда)",
          "example": null
        },
        "peak_km": {
          "type": "integer",
          "description": "Пик проблем — на каком пробеге чаще всего",
          "example": 40000
        },
        "early_cases_km": {
          "type": "integer",
          "description": "Самые ранние случаи",
          "example": 15000
        },
        "frequency_percent": {
          "type": ["integer", "null"],
          "description": "Частота (%) среди владельцев. null если нет статистики",
          "example": 35
        },
        "frequency_description": {
          "type": ["string", "null"],
          "description": "Текстовое описание частоты для UI ('У каждого третьего владельца', 'Часто упоминается'). Используется когда нет точного процента.",
          "example": "У каждого третьего владельца"
        },
        "age_related": {
          "type": "boolean",
          "description": "Зависит ли от возраста (а не только пробега)",
          "example": false
        },
        "age_years": {
          "type": ["integer", "null"],
          "description": "Через сколько лет проявляется (если age_related=true)",
          "example": null
        },
        "climate_dependent": {
          "type": "boolean",
          "description": "Зависит ли проявление от климата (зима, реагенты, жара)",
          "example": false
        },
        "climate_note": {
          "type": ["string", "null"],
          "description": "Описание зависимости от климата",
          "example": "Проявляется в тёплое время года, в пробках"
        }
      }
    },

    "solutions": {
      "type": "array",
      "description": "РЕШЕНИЯ — как починить",
      "items": {
        "type": "object",
        "required": ["type", "title"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["correct", "temporary", "preventive", "workaround", "replacement", "repair", "maintenance", "modification"],
            "description": "Тип решения. correct=правильное универсальное решение; replacement=замена детали; repair=ремонт без замены; temporary=временное решение; preventive=превентивная мера; maintenance=плановое обслуживание; workaround=обходной путь; modification=модификация (например, удаление катализатора)",
            "example": "correct"
          },
          "title": {
            "type": "string",
            "example": "Замена датчика на ревизию 2"
          },
          "description": {
            "type": "string",
            "example": "Заменить датчик на обновлённую версию"
          },
          "diy_possible": {
            "type": "boolean",
            "example": true
          },
          "diy_difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard", "professional_only"],
            "example": "easy"
          },
          "diy_difficulty_score": {
            "type": ["integer", "null"],
            "description": "Численная шкала сложности DIY: 1=элементарно, 2=легко, 3=средне, 4=сложно, 5=очень сложно",
            "minimum": 1,
            "maximum": 5,
            "example": 2
          },
          "diy_time_hours": {
            "type": "number",
            "example": 0.5
          },
          "diy_tools": {
            "type": "array",
            "items": {"type": "string"},
            "example": ["Ключ на 24", "Ветошь"]
          },
          "diy_warning": {
            "type": ["string", "null"],
            "description": "Важные предупреждения для DIY",
            "example": "Подстелите ветошь — польётся топливо"
          },
          "service_time_hours": {
            "type": "number",
            "description": "Время работы на СТО",
            "example": 0.3
          },
          "service_recommendation": {
            "type": "string",
            "description": "Какой сервис рекомендуется: 'любой' = подойдёт любая СТО, 'специализированный' = нужен профильный сервис, 'только_дилер' = только официальный дилер",
            "enum": ["любой", "специализированный", "только_дилер"],
            "example": "любой"
          },
          "labor_cost": {
            "type": "object",
            "properties": {
              "min": {"type": "integer"},
              "max": {"type": "integer"},
              "currency": {"type": "string", "default": "RUB"},
              "as_of_date": {"type": "string", "format": "date"}
            },
            "example": {"min": 500, "max": 1500, "currency": "RUB", "as_of_date": "2025-01"}
          },
          "effectiveness": {
            "type": "string",
            "enum": ["permanent", "temporary", "uncertain"],
            "example": "permanent"
          },
          "side_effects": {
            "type": "array",
            "items": {"type": "string"},
            "example": []
          },
          "consumables": {
            "type": "array",
            "description": "Расходники нужные для решения (герметик, прокладки, смазка) — в дополнение к основным parts",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string", "example": "Резьбовой герметик Loctite 243"},
                "part_number": {"type": ["string", "null"]},
                "quantity": {"type": "integer", "default": 1},
                "is_one_time_use": {"type": "boolean", "default": true},
                "note": {"type": ["string", "null"], "example": "малый тюбик хватит"}
              }
            }
          },
          "torque_specs": {
            "type": "array",
            "description": "Моменты затяжки болтов/гаек для сложного ремонта",
            "items": {
              "type": "object",
              "properties": {
                "fastener": {"type": "string", "example": "Болт головки блока цилиндров"},
                "torque_nm": {"type": ["number", "null"], "example": 30},
                "angle_deg": {"type": ["number", "null"], "example": 90, "description": "Дополнительный угол после момента (для болтов с пластической деформацией)"},
